<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RAYA | Coastal Apparel Studio</title>
    <!-- Modern Premium Font Family -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    
    <style>
        :root {
            /* Beach Inspired Color Palette */
            --bg-primary: #fbf9f6;       /* Soft, warm sand/eggshell background */
            --bg-card: #ffffff;          /* Clean crisp linen white */
            --text-main: #1e293b;        /* Deep ocean navy/slate */
            --text-muted: #64748b;       /* Sea glass gray-blue */
            --accent-ocean: #2c7a7b;     /* Deep coastal teal */
            --accent-sand: #dfd3c3;      /* Muted driftwood tan */
            --accent-sunset: #e28743;    /* Warm coral/sunset orange */
            --border-color: #f1ebd9;     /* Soft sand tint border */
            --radius-lg: 20px;
            --radius-md: 14px;
            --shadow-subtle: 0 8px 30px rgba(223, 211, 195, 0.2);
            --shadow-hover: 0 15px 35px rgba(44, 122, 123, 0.08);
            --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-main);
            overflow-x: hidden;
            padding-bottom: 60px;
        }

        /* Coastal Elegant Navbar */
        nav {
            position: sticky;
            top: 0;
            background: rgba(253, 249, 246, 0.85); /* Blurred beach glass background */
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border-color);
            z-index: 100;
            padding: 24px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            font-size: 1.8rem;
            letter-spacing: 2px;
            color: var(--text-main);
        }

        .cart-trigger {
            background: var(--text-main);
            color: #ffffff;
            border: none;
            padding: 12px 24px;
            border-radius: 30px; /* Fully rounded capsule style */
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: var(--transition);
        }

        .cart-trigger:hover {
            background: var(--accent-ocean);
            transform: translateY(-1px);
        }

        .cart-count {
            background: rgba(255, 255, 255, 0.2);
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Beach Theme Banner Hook */
        .hero-banner {
            text-align: center;
            padding: 60px 20px 20px 20px;
            max-width: 800px;
            margin: 0 auto;
        }

        .hero-banner h2 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 400;
            font-style: italic;
            margin-bottom: 12px;
            color: var(--accent-ocean);
        }

        .hero-banner p {
            color: var(--text-muted);
            font-size: 1rem;
            letter-spacing: 0.5px;
        }

        /* Filter Tabs */
        .controls {
            max-width: 1200px;
            margin: 30px auto 20px auto;
            padding: 0 20px;
            display: flex;
            justify-content: center;
            gap: 16px;
        }

        .filter-btn {
            background: transparent;
            border: 1px solid transparent;
            padding: 10px 24px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.9rem;
            color: var(--text-muted);
            transition: var(--transition);
        }

        .filter-btn.active, .filter-btn:hover {
            border-color: var(--accent-sand);
            color: var(--text-main);
            background: var(--bg-card);
        }

        /* Catalog Layout Grid */
        .catalog-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Coastal Lifestyle Cards */
        .card {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            padding: 20px;
            display: flex;
            flex-direction: column;
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-subtle);
            transition: var(--transition);
        }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-hover);
            border-color: var(--accent-sand);
        }

        /* Warm Sand/Canvas 100px Image Holder Frame */
        .image-wrapper {
            width: 100%;
            height: 240px; 
            background-color: #f6f3ed; /* Very subtle warm towel/sand hue */
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            overflow: hidden;
        }

        /* Your exact 100px constraint style preserved */
        .image-wrapper img {
            width: 100px;
            height: 100px;
            object-fit: contain;
            filter: drop-shadow(0 10px 20px rgba(30,41,59,0.08));
            transition: var(--transition);
        }

        .card:hover .image-wrapper img {
            transform: scale(1.1) rotate(2deg);
        }

        .card-category {
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--accent-sunset);
            font-weight: 700;
            letter-spacing: 1.5px;
            margin-bottom: 6px;
        }

        .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            font-weight: 400;
            color: var(--text-main);
            margin-bottom: 16px;
            line-height: 1.3;
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
            width: 100%;
            padding-top: 14px;
            border-top: 1px solid var(--border-color);
        }

        .card-price {
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--text-main);
        }

        .add-to-cart {
            background: none;
            border: 1.5px solid var(--text-main);
            color: var(--text-main);
            padding: 8px 18px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            transition: var(--transition);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .add-to-cart:hover {
            background: var(--text-main);
            color: #ffffff;
        }

        /* Shopping Beach Bag Drawer */
        .cart-drawer {
            position: fixed;
            top: 0;
            right: -420px;
            width: 100%;
            max-width: 420px;
            height: 100vh;
            background: var(--bg-card);
            box-shadow: -15px 0 40px rgba(30,41,59,0.05);
            z-index: 200;
            transition: var(--transition);
            padding: 40px;
            display: flex;
            flex-direction: column;
            border-left: 1px solid var(--border-color);
        }

        .cart-drawer.open {
            right: 0;
        }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        .cart-header h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
        }

        .close-cart {
            background: none;
            border: none;
            font-size: 2rem;
            cursor: pointer;
            color: var(--text-muted);
            line-height: 1;
        }

        .cart-items {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .cart-item {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .cart-item-img {
            width: 60px;
            height: 60px;
            background: #f6f3ed;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .cart-item-img img {
            width: 40px;
            height: 40px;
            object-fit: contain;
        }

        .cart-item-details h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .cart-item-details p {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .cart-total-section {
            margin-top: auto;
            padding-top: 30px;
            border-top: 1px solid var(--border-color);
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            font-weight: 600;
            font-size: 1.25rem;
            margin-bottom: 24px;
        }

        .checkout-btn {
            width: 100%;
            background: var(--accent-ocean);
            color: white;
            border: none;
            padding: 18px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: var(--transition);
        }

        .checkout-btn:hover {
            background: var(--text-main);
        }

        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(30, 41, 59, 0.15);
            backdrop-filter: blur(6px);
            z-index: 150;
            display: none;
        }

        .overlay.visible {
            display: block;
        }
    </style>
</head>
<body>

    <nav>
        <div class="logo">RAYA</div>
        <button class="cart-trigger" id="cartBtn">
            Beach Bag <span class="cart-count" id="cartCount">0</span>
        </button>
    </nav>

    <div class="hero-banner">
        <h2>Designed for the Sun</h2>
        <p>Premium modern linen and essentials built for slow coastal days.</p>
    </div>

    <!-- Filters -->
    <div class="controls">
        <button class="filter-btn active" onclick="filterCatalog('all', this)">All Items</button>
        <button class="filter-btn" onclick="filterCatalog('resort', this)">Resortwear</button>
        <button class="filter-btn" onclick="filterCatalog('swim-surf', this)">Swim & Surf</button>
    </div>

    <!-- Main Grid -->
    <main class="catalog-container" id="catalog"></main>

    <!-- Cart Overlay & Drawer -->
    <div class="overlay" id="overlay"></div>
    <div class="cart-drawer" id="cartDrawer">
        <div class="cart-header">
            <h3>Your Bag</h3>
            <button class="close-cart" id="closeCart">&times;</button>
        </div>
        <div class="cart-items" id="cartItems"></div>
        <div class="cart-total-section">
            <div class="total-row">
                <span>Total</span>
                <span id="cartTotal">$0.00</span>
            </div>
            <button class="checkout-btn">Secure Checkout</button>
        </div>
    </div>

    <script>
        // Catalog data with beach categories and updated copy
        const products = [
            { id: 1, name: "Malibu Linen Tee", price: 44.00, image: "pictures/shirt1.png", category: "resort" },
            { id: 2, name: "Outrigger Button-Up", price: 78.00, image: "pictures/shirt2.png", category: "resort" },
            { id: 3, name: "Tidal Knit Polo", price: 65.00, image: "pictures/shirt3.png", category: "resort" },
            { id: 4, name: "Driftwood Sun V-Neck", price: 38.00, image: "pictures/shirt1.png", category: "resort" },
            { id: 5, name: "Offshore Heavy Hoodie", price: 92.00, image: "pictures/shirt2.png", category: "swim-surf" },
            { id: 6, name: "Coral Sun Crewneck", price: 84.00, image: "pictures/shirt3.png", category: "swim-surf" }
        ];

        let cart = [];

        const catalogContainer = document.getElementById('catalog');
        const cartDrawer = document.getElementById('cartDrawer');
        const cartBtn = document.getElementById('cartBtn');
        const closeCart = document.getElementById('closeCart');
        const overlay = document.getElementById('overlay');
        const cartItemsContainer = document.getElementById('cartItems');
        const cartCountEl = document.getElementById('cartCount');
        const cartTotalEl = document.getElementById('cartTotal');

        function renderCatalog(itemsToRender = products) {
            catalogContainer.innerHTML = itemsToRender.map(product => `
                <div class="card">
                    <div class="image-wrapper">
                        <img src="${product.image}" alt="${product.name}">
                    </div>
                    <div class="card-category">${product.category}</div>
                    <h2 class="card-title">${product.name}</h2>
                    <div class="card-footer">
                        <span class="card-price">$${product.price.toFixed(2)}</span>
                        <button class="add-to-cart" onclick="addToCart(${product.id})">Add to Bag</button>
                    </div>
                </div>
            `).join('');
        }

        function filterCatalog(category, buttonEl) {
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            buttonEl.classList.add('active');
            
            if (category === 'all') {
                renderCatalog(products);
            } else {
                const filtered = products.filter(p => p.category === category);
                renderCatalog(filtered);
            }
        }

        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            const existingItem = cart.find(item => item.id === productId);

            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({ ...product, quantity: 1 });
            }
            updateCartUI();
            openCartDrawer();
        }

        function updateCartUI() {
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            cartCountEl.innerText = totalItems;

            const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            cartTotalEl.innerText = `$${totalPrice.toFixed(2)}`;

            if (cart.length === 0) {
                cartItemsContainer.innerHTML = `<p style="color: var(--text-muted); text-align: center; margin-top: 40px;">Your beach bag is empty.</p>`;
            } else {
                cartItemsContainer.innerHTML = cart.map(item => `
                    <div class="cart-item">
                        <div class="cart-item-img">
                            <img src="${item.image}" alt="${item.name}">
                        </div>
                        <div class="cart-item-details">
                            <h4>${item.name}</h4>
                            <p>$${item.price.toFixed(2)} &times; ${item.quantity}</p>
                        </div>
                    </div>
                `).join('');
            }
        }

        function openCartDrawer() {
            cartDrawer.classList.add('open');
            overlay.classList.add('visible');
        }

        function closeCartDrawer() {
            cartDrawer.classList.remove('open');
            overlay.classList.remove('visible');
        }

        cartBtn.addEventListener('click', openCartDrawer);
        closeCart.addEventListener('click', closeCartDrawer);
        overlay.addEventListener('click', closeCartDrawer);

        renderCatalog();
        updateCartUI();
    </script>
</body>
</html>
